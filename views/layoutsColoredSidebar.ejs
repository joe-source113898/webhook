<!DOCTYPE html>
<html lang="en">

<head>
  
  <meta charset="utf-8" />
  <title><%- title %> | Symox - Admin & Dashboard Template</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta content="Premium Multipurpose Admin & Dashboard Template" name="description">
  <meta content="Themesbrand" name="author">
  <!-- App favicon -->
  <link rel="shortcut icon" href="public/assets/images/favicon.ico">

  <base href="/">

  <%- HeaderCss %>
  
  <%- include ('./Partials/HeaderStyle') %>

</head>

<body data-layout="vertical" data-sidebar="brand">

  <!-- Begin page -->
  <div id="layout-wrapper">

    <%- include ('./Partials/Topbar') %>
    <%- include ('./Partials/Sidebar') %>
    <%- include ('./Partials/Horizontal') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <%- breadcrumb %>
          
          <%- body %>

        </div>
      </div>
      <%- include ('./Partials/Footer') %>
    </div>
  </div>

  <%- include ('./Partials/Rightbar')  %>
  <%- include ('./Partials/VendorScript')  %>

  <%- FooterJs %>

  <script>
    sessionStorage.setItem("is_visited", "layout-direction-ltr");
  </script>

  <script src="public/assets/js/app.js"></script>

  <%- BottomJs %>
</body>

</html>